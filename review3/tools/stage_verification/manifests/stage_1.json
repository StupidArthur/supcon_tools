  ],
  "git_diff_check": true,
  "gates": [
    {"id": "scope_and_stage_boundary", "mode": "automated", "description": "修改局限于无损模板服务和模板状态，且未提前实现阶段 2。", "checks": ["required_documents", "required_paths", "preserved_paths", "manifest_locked", "locked_files", "locked_acceptance_files", "changed_paths_allowed", "forbidden_paths", "forbidden_symbols", "git_diff_check"]},
    {"id": "lossless_and_state_contract", "mode": "automated", "description": "无损 YAML、冲突保护、三份状态、校验和回归由 Go、前端和 Python 测试证明。", "checks": ["command:frontend_tests", "command:frontend_build", "command:go_template", "command:wails_build", "command:python_dsl"]}
  ]
}
