  "allowed_paths": ["config-tool/internal/config/**", "config-tool/internal/bindings/template_config.go", "config-tool/internal/app/container.go", "config-tool/main.go", "config-tool/go.mod", "config-tool/go.sum", "config-tool/frontend/src/App.tsx", "config-tool/frontend/src/features/templates/**", "config-tool/frontend/src/lib/api.ts", "config-tool/frontend/src/style.css", "config-tool/frontend/wailsjs/**", "config-tool/frontend/package.json.md5", "tests/test_structured_dsl.py", "tests/test_tank_pid_configs.py"],
