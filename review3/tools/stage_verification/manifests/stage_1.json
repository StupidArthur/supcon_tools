  "required_paths": ["config-tool/internal/config/template_service.go", "config-tool/internal/config/template_service_test.go", "config-tool/frontend/src/features/templates/useTemplateStore.ts", "config-tool/frontend/src/features/templates/secondOrderTank/definition.ts"],
  "forbidden_symbols": [{"id": "no_stage_2_pid_diagram", "path_globs": ["config-tool/frontend/src/features/templates/**"], "pattern": "SecondOrderTankDiagram|SecondOrderTankInspector|RuntimeToolbar|<svg"}],
  "locked_paths": ["todo/second_order_tank_*.md", "tools/stage_verification/**"],
  "locked_acceptance_paths": ["tests/test_*.py", "config-tool/frontend/src/**/*.test.ts", "config-tool/frontend/src/**/*.test.tsx", "config-tool/internal/**/*_test.go", "config-tool/internal/config/template_service_test.go", "config-tool/frontend/src/features/templates/useTemplateStore.test.ts"],
  "commands": [
    {"id": "frontend_tests", "cwd": "config-tool/frontend", "argv": ["npm", "run", "test:run"], "windows_argv": ["npm.cmd", "run", "test:run"], "timeout_seconds": 300},
    {"id": "frontend_build", "cwd": "config-tool/frontend", "argv": ["npm", "run", "build"], "windows_argv": ["npm.cmd", "run", "build"], "timeout_seconds": 300},
    {"id": "go_template", "cwd": "config-tool", "argv": ["go", "test", "./internal/config", "./internal/bindings"], "timeout_seconds": 300, "env": {"GOCACHE": "{temp}/review3-go-cache"}},
    {"id": "wails_build", "cwd": "config-tool", "argv": ["wails", "build"], "timeout_seconds": 600, "env": {"GOCACHE": "{temp}/review3-go-cache"}},
