  "allowed_paths": [".gitignore", "config-tool/frontend/package.json", "config-tool/frontend/package-lock.json", "config-tool/frontend/package.json.md5", "config-tool/frontend/vite.config.ts", "config-tool/frontend/vitest.config.ts", "config-tool/frontend/src/lib/**", "config-tool/frontend/src/test/**", "config-tool/frontend/src/**/*.test.ts", "config-tool/frontend/src/**/*.test.tsx", "config-tool/frontend/src/App.tsx", "config-tool/frontend/src/components/Toolbar.tsx", "config-tool/frontend/src/components/SystemPanel.tsx", "config-tool/frontend/src/components/SimulationPanel.tsx", "config-tool/frontend/src/store/useCanvasStore.ts", "config-tool/frontend/wailsjs/**", "config-tool/go.mod", "config-tool/go.sum"],
  "forbidden_paths": ["components/programs/pid.py", "components/programs/valve.py", "components/programs/cylindrical_tank.py", "components/programs/base.py", "datacenter/opcua_server.py", "config/单阀门二阶水箱.yaml", "debug_gui/**", "config-tool/frontend/src/features/templates/**", "config-tool/frontend/src/features/runtime/**"],
