{
  "schema_version": 1,
  "stage": 3,
  "name": "Wails 受管进程、API ready 和清理",
  "required_documents": ["todo/second_order_tank_agent_start_here.md", "todo/second_order_tank_visual_dsl_template_design.md", "todo/second_order_tank_repository_contracts.md", "todo/second_order_tank_implementation_playbook.md"],
  "allowed_paths": ["config-tool/internal/bindings/system.go", "config-tool/internal/bindings/system_test.go", "config-tool/internal/app/lifecycle.go", "config-tool/internal/app/container.go", "config-tool/main.go", "config-tool/frontend/src/features/templates/RuntimeToolbar.tsx", "config-tool/frontend/src/features/templates/RuntimeToolbar.test.tsx", "config-tool/frontend/src/features/templates/useTemplateStore.ts", "config-tool/frontend/src/components/SystemPanel.tsx", "config-tool/frontend/src/lib/api.ts", "config-tool/frontend/wailsjs/**", "config-tool/frontend/package.json.md5", "config-tool/go.mod", "config-tool/go.sum"],
  "forbidden_paths": ["components/programs/pid.py", "components/programs/valve.py", "components/programs/cylindrical_tank.py", "components/programs/base.py", "datacenter/opcua_server.py", "config/单阀门二阶水箱.yaml", "debug_gui/**", "datacenter/engine_api.py", "controller/engine.py", "config-tool/frontend/src/features/runtime/**"],
  "preserved_paths": ["config-tool/frontend/src/components/Canvas.tsx", "config-tool/frontend/src/components/Palette.tsx", "config-tool/frontend/src/components/PropertyPanel.tsx", "config-tool/frontend/src/components/SimulationPanel.tsx", "config-tool/frontend/src/store/useCanvasStore.ts"],
  "required_paths": ["config-tool/internal/bindings/system_test.go", "config-tool/frontend/src/features/templates/RuntimeToolbar.test.tsx"],
  "forbidden_symbols": [{"id": "no_stage_4_runtime_transport", "path_globs": ["config-tool/frontend/src/**", "config-tool/internal/**"], "pattern": "WebSocket|/ws/snapshot|fetchSnapshot|latestSnapshotAt|staleThreshold"}],
  "locked_paths": ["todo/second_order_tank_*.md", "tools/stage_verification/**"],
  "locked_acceptance_paths": ["tests/test_*.py", "config-tool/frontend/src/**/*.test.ts", "config-tool/frontend/src/**/*.test.tsx", "config-tool/internal/**/*_test.go", "config-tool/internal/bindings/system_test.go", "config-tool/frontend/src/features/templates/RuntimeToolbar.test.tsx"],
  "commands": [
    {"id": "go_bindings_race", "cwd": "config-tool", "argv": ["go", "test", "-race", "./internal/bindings", "-count=1"], "timeout_seconds": 300, "env": {"GOCACHE": "{temp}/review3-go-cache"}},
    {"id": "go_all", "cwd": "config-tool", "argv": ["go", "test", "./..."], "timeout_seconds": 300, "env": {"GOCACHE": "{temp}/review3-go-cache"}},
    {"id": "frontend_tests", "cwd": "config-tool/frontend", "argv": ["npm", "run", "test:run"], "windows_argv": ["npm.cmd", "run", "test:run"], "timeout_seconds": 300},
    {"id": "frontend_build", "cwd": "config-tool/frontend", "argv": ["npm", "run", "build"], "windows_argv": ["npm.cmd", "run", "build"], "timeout_seconds": 300},
    {"id": "wails_build", "cwd": "config-tool", "argv": ["wails", "build"], "timeout_seconds": 600, "env": {"GOCACHE": "{temp}/review3-go-cache"}},
    {"id": "python_baseline", "cwd": ".", "argv": ["{python}", "-m", "pytest", "tests/test_tank_pid_configs.py", "tests/test_pid_industrial.py", "tests/test_structured_dsl.py", "-q"], "timeout_seconds": 300}
  ],
  "git_diff_check": true,
  "gates": [
    {"id": "scope_and_stage_boundary", "mode": "automated", "description": "改动局限于唯一 Wails 进程管理入口，未进入实时传输阶段。", "checks": ["required_documents", "required_paths", "preserved_paths", "manifest_locked", "locked_files", "locked_acceptance_files", "changed_paths_allowed", "forbidden_paths", "forbidden_symbols", "git_diff_check"]},
    {"id": "managed_process_contract", "mode": "automated", "description": "启动参数、ready、并发、停止清理、运行身份和 UI 状态由 race/回归测试与 Wails build 证明。", "checks": ["command:go_bindings_race", "command:go_all", "command:frontend_tests", "command:frontend_build", "command:wails_build", "command:python_baseline"]}
  ]
}
