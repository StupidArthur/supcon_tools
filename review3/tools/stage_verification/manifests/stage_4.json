{
  "schema_version": 1,
  "stage": 4,
  "name": "REST、WebSocket 和真实现场快照",
  "required_documents": [
    "todo/second_order_tank_agent_start_here.md",
    "todo/second_order_tank_visual_dsl_template_design.md",
    "todo/second_order_tank_repository_contracts.md",
    "todo/second_order_tank_implementation_playbook.md"
  ],
  "allowed_paths": [
    "datacenter/engine_api.py",
    "controller/engine.py",
    "standalone_main.py",
    "tests/test_engine_api.py",
    "config-tool/frontend/src/features/runtime/**",
    "config-tool/frontend/src/features/templates/**",
    "config-tool/frontend/src/App.tsx",
    "config-tool/frontend/src/style.css"
  ],
  "forbidden_paths": [
    "components/programs/pid.py",
    "components/programs/valve.py",
    "components/programs/cylindrical_tank.py",
    "components/programs/base.py",
    "datacenter/opcua_server.py",
    "config/单阀门二阶水箱.yaml",
    "debug_gui/**",
    "config-tool/internal/**"
  ],
  "preserved_paths": [
    "config-tool/frontend/src/components/Canvas.tsx",
    "config-tool/frontend/src/components/Palette.tsx",
    "config-tool/frontend/src/components/PropertyPanel.tsx",
    "config-tool/frontend/src/components/SimulationPanel.tsx",
    "config-tool/frontend/src/store/useCanvasStore.ts"
  ],
  "required_paths": [
    "tests/test_engine_api.py",
    "config-tool/frontend/src/features/runtime/types.ts",
    "config-tool/frontend/src/features/runtime/runtimeApi.ts",
    "config-tool/frontend/src/features/runtime/useRuntimeStore.ts",
    "config-tool/frontend/src/features/runtime/websocket.ts",
    "config-tool/frontend/src/features/runtime/trendBuffer.ts",
    "config-tool/frontend/src/features/runtime/*.test.ts"
  ],
  "forbidden_symbols": [
    {
      "id": "no_stage_5_atomic_writes",
      "path_globs": [
        "controller/**",
        "datacenter/**",
        "tests/**",
        "config-tool/frontend/src/**"
      ],
      "pattern": "queue_batch|queueBatch|/writes|PidFaceplate|runtimeOverrides|atomic[_ -]?writes"
    }
  ],
  "locked_paths": [
    "todo/second_order_tank_*.md",
    "tools/stage_verification/**"
  ],
  "locked_acceptance_paths": [
    "tools/stage_verification/acceptance/SECOND_ORDER_TANK_ACCEPTANCE_SPEC.md",
    "tools/stage_verification/acceptance/CONTRACT_SURFACES.md",
    "tools/stage_verification/acceptance/stage_0/test_stage_0_acceptance.py",
    "config-tool/frontend/acceptance/stage_0/api_wrapper.acceptance.test.ts",
    "config-tool/frontend/acceptance/stage_0/legacy_views.acceptance.test.tsx",
    "tools/stage_verification/acceptance/stage_1/test_stage_1_acceptance.py",
    "config-tool/acceptance/stage_1/template_service_acceptance_test.go",
    "config-tool/frontend/acceptance/stage_1/template_store.acceptance.test.ts",
    "tools/stage_verification/acceptance/stage_2/test_stage_2_acceptance.py",
    "config-tool/frontend/acceptance/stage_2/pid_diagram.acceptance.test.tsx",
    "config-tool/frontend/acceptance/stage_2/inspector.acceptance.test.tsx",
    "tools/stage_verification/evidence/stage_2/pid_visual_review.md",
    "tools/stage_verification/evidence/stage_2/minimum_viewport_review.md",
    "tools/stage_verification/acceptance/stage_3/test_stage_3_acceptance.py",
    "config-tool/acceptance/stage_3/system_binding_acceptance_test.go",
    "config-tool/frontend/acceptance/stage_3/runtime_toolbar_state.acceptance.test.tsx",
    "tools/stage_verification/acceptance/stage_4/test_stage_4_acceptance.py",
    "config-tool/frontend/acceptance/stage_4/runtime_diagram.acceptance.test.tsx",
    "config-tool/frontend/acceptance/stage_4/runtime_store.acceptance.test.ts",
    "config-tool/frontend/acceptance/stage_4/runtime_api.acceptance.test.ts"
  ],
  "commands": [
    {
      "id": "verifier_self_tests",
      "cwd": ".",
      "argv": [
        "{python}",
        "-m",
        "pytest",
        "tools/stage_verification/tests",
        "-q"
      ],
      "timeout_seconds": 300
    },
    {
      "id": "python_reviewer_acceptance",
      "cwd": ".",
      "argv": [
        "{python}",
        "-m",
        "pytest",
        "tools/stage_verification/acceptance/stage_4",
        "-q"
      ],
      "timeout_seconds": 300
    },
    {
      "id": "frontend_reviewer_acceptance",
      "cwd": "config-tool/frontend",
      "argv": [
        "npm",
        "run",
        "test:acceptance",
        "--",
        "acceptance/stage_4"
      ],
      "windows_argv": [
        "npm.cmd",
        "run",
        "test:acceptance",
        "--",
        "acceptance/stage_4"
      ],
      "timeout_seconds": 300
    },
    {
      "id": "python_runtime_api",
      "cwd": ".",
      "argv": [
        "{python}",
        "-m",
        "pytest",
        "tests/test_engine_api.py",
        "tests/test_tank_pid_configs.py",
        "tests/test_pid_industrial.py",
        "tests/test_structured_dsl.py",
        "-q"
      ],
      "timeout_seconds": 300
    },
    {
      "id": "frontend_tests",
      "cwd": "config-tool/frontend",
      "argv": [
        "npm",
        "run",
        "test:run"
      ],
      "windows_argv": [
        "npm.cmd",
        "run",
        "test:run"
      ],
      "timeout_seconds": 300
    },
    {
      "id": "frontend_build",
      "cwd": "config-tool/frontend",
      "argv": [
        "npm",
        "run",
        "build"
      ],
      "windows_argv": [
        "npm.cmd",
        "run",
        "build"
      ],
      "timeout_seconds": 300
    },
    {
      "id": "go_all",
      "cwd": "config-tool",
      "argv": [
        "go",
        "test",
        "./..."
      ],
      "timeout_seconds": 300,
      "env": {
        "GOCACHE": "{temp}/review3-go-cache"
      }
    }
  ],
  "git_diff_check": true,
  "gates": [
    {
      "id": "scope_and_stage_boundary",
      "mode": "automated",
      "description": "实时读链路改动在允许范围内，核心算法未动且没有提前实现原子写值。",
      "checks": [
        "required_documents",
        "required_paths",
        "preserved_paths",
        "manifest_locked",
        "locked_files",
        "locked_acceptance_files",
        "changed_paths_allowed",
        "forbidden_paths",
        "forbidden_symbols",
        "git_diff_check"
      ]
    },
    {
      "id": "real_snapshot_contract",
      "mode": "automated",
      "description": "真实 snapshot、runtimeName、心跳、stale、断线冻结、REST 后重连、慢消费者与 UI 数据源均由测试和构建证明。",
      "checks": [
        "command:verifier_self_tests",
        "command:python_reviewer_acceptance",
        "command:frontend_reviewer_acceptance",
        "command:python_runtime_api",
        "command:frontend_tests",
        "command:frontend_build",
        "command:go_all"
      ]
    }
  ]
}
