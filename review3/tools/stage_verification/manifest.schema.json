{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Second-order tank stage verification manifest",
  "type": "object",
  "required": [
    "schema_version", "stage", "name", "required_documents", "allowed_paths",
    "forbidden_paths", "preserved_paths", "required_paths", "forbidden_symbols",
    "locked_paths", "locked_acceptance_paths", "commands", "git_diff_check", "gates"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "stage": {"type": "integer", "minimum": 0, "maximum": 8},
    "name": {"type": "string", "minLength": 1},
    "required_documents": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "allowed_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "forbidden_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "preserved_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "required_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "locked_paths": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "locked_acceptance_paths": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "git_diff_check": {"type": "boolean"},
    "forbidden_symbols": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path_globs", "pattern"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "path_globs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "pattern": {"type": "string", "minLength": 1},
          "scope": {"enum": ["changed", "repository"]},
          "max_bytes": {"type": "integer", "exclusiveMinimum": 0}
        },
        "additionalProperties": false
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "cwd", "argv", "timeout_seconds"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "cwd": {"type": "string", "minLength": 1},
          "argv": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "windows_argv": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "timeout_seconds": {"type": "number", "exclusiveMinimum": 0},
          "env": {"type": "object", "additionalProperties": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "mode", "description"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "mode": {"enum": ["automated", "manual"]},
          "description": {"type": "string", "minLength": 1},
          "checks": {"type": "array", "items": {"type": "string", "minLength": 1}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
